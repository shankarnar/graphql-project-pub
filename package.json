{
  "name": "graphql-api-project",
  "version": "1.0.0",
  "description": "A GraphQL API built with Node.js, Express, and GraphQL Yoga",
  "main": "src/server.js",
  "scripts": {
    "build": "tsc",
    "start": "NODE_ENV=production node dist/server.js",
    "dev": "NODE_ENV=development ts-node src/server.ts",
    "dev:watch": "NODE_ENV=development ts-node --watch src/server.ts",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:ci": "NODE_ENV=test jest --ci --coverage --watchAll=false",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prestart": "npm run build"
  },
  "keywords": [
    "graphql",
    "nodejs",
    "express",
    "api",
    "json",
    "graphql-yoga",
    "rest-api"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/graphql-api-project.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/graphql-api-project/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/graphql-api-project#readme",
  "dependencies": {
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-yoga": "^3.9.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "eslint": "^8.57.0",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.5",
    "typescript": "^5.2.2",
    "@types/node": "^20.8.0",
    "ts-node": "^10.9.1",
    "ts-jest": "^29.1.1",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "tsconfig-paths": "^4.2.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/data/**",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ]
  }
}