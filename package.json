{
  "name": "graphql-api-project",
  "version": "1.0.0",
  "description": "A GraphQL API built with Node.js, Express, and GraphQL Yoga",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "echo 'Linting skipped'",
    "lint:fix": "echo 'Linting skipped'",
    "format": "echo 'Formatting skipped'",
    "format:check": "echo 'Format check skipped'",
    "build": "echo 'No build step required'",
    "clean": "rm -rf coverage/ logs/ node_modules/.cache",
    "precommit": "npm run test:ci"
  },
  "keywords": [
    "graphql",
    "nodejs",
    "express",
    "api",
    "json",
    "graphql-yoga",
    "rest-api"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/graphql-api-project.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/graphql-api-project/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/graphql-api-project#readme",
  "dependencies": {
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-yoga": "^5.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "eslint": "^8.57.0",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/data/**",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ]
  }
}